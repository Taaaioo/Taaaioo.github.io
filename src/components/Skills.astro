---
---

<section id="skills" class="py-20 px-4 sm:px-6 lg:px-8 parallax-container relative">
  <!-- Parallax background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-0 w-64 h-64 bg-accent rounded-full opacity-5 blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-20 left-1/3 w-48 h-48 bg-blue-600 rounded-full opacity-5 blur-3xl animate-rotate"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <h2 class="text-4xl md:text-5xl font-bold mb-12 text-slate-50 animate-slide-up">Skills & Technologies</h2>
    
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-slate-800 rounded-lg p-6 border border-slate-700 hover:border-accent transition-all duration-300 hover-lift animate-slide-up group">
        <div class="text-accent text-3xl mb-4 group-hover:animate-rotate transition-transform">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-50">Frontend</h3>
        <ul class="space-y-2 text-slate-400">
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>React & Next.js</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>TypeScript</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>Tailwind CSS</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>Astro</li>
        </ul>
      </div>

      <div class="bg-slate-800 rounded-lg p-6 border border-slate-700 hover:border-accent transition-all duration-300 hover-lift animate-stagger-1 group">
        <div class="text-accent text-3xl mb-4 group-hover:animate-rotate transition-transform">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-50">Backend</h3>
        <ul class="space-y-2 text-slate-400">
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>Node.js & Express</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>Python & Django</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>PostgreSQL & MongoDB</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>REST APIs & GraphQL</li>
        </ul>
      </div>

      <div class="bg-slate-800 rounded-lg p-6 border border-slate-700 hover:border-accent transition-all duration-300 hover-lift animate-stagger-2 group">
        <div class="text-accent text-3xl mb-4 group-hover:animate-rotate transition-transform">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-50">DevOps & Cloud</h3>
        <ul class="space-y-2 text-slate-400">
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>AWS (EC2, S3, Lambda)</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>Docker & Kubernetes</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>CI/CD (GitHub Actions)</li>
          <li class="flex items-center hover:translate-x-2 transition-transform duration-200"><span class="w-2 h-2 bg-accent rounded-full mr-2 animate-pulse"></span>Git & Linux</li>
        </ul>
      </div>
    </div>
  </div>
</section>
