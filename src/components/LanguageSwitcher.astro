---
// Language Switcher Component with Enhanced Styling
import { setLanguage } from '../i18n/translations';
---

<div id="language-switcher" class="flex items-center gap-1 p-1 bg-slate-800/50 rounded-lg backdrop-blur border border-slate-700/50 hover:border-slate-600/50 transition-all duration-300">
  <button 
    data-lang="en" 
    class="lang-btn lang-en px-3 py-1.5 rounded-md text-sm font-semibold transition-all duration-300 flex items-center gap-1.5 active"
    aria-label="Switch to English"
    title="English"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" stroke="currentColor" fill="none" stroke-width="2"/>
      <path d="M12 2a10 10 0 0 1 0 20 10 10 0 0 1 0-20z" stroke="none"/>
      <path d="M2 12h20M12 2a4.3 4.3 0 0 1 0 20 4.3 4.3 0 0 1 0-20z" stroke="currentColor" fill="none" stroke-width="2"/>
    </svg>
    EN
  </button>
  <div class="w-px h-4 bg-slate-600/50"></div>
  <button 
    data-lang="ar" 
    class="lang-btn lang-ar px-3 py-1.5 rounded-md text-sm font-semibold transition-all duration-300 flex items-center gap-1.5"
    aria-label="Switch to Arabic"
    title="العربية"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" stroke="currentColor" fill="none" stroke-width="2"/>
      <path d="M8 12h8M8 16h8M8 8h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    العربية
  </button>
</div>

<style>
  .lang-btn {
    color: rgb(148, 163, 184);
    background-color: transparent;
  }

  .lang-btn:hover {
    background-color: rgba(59, 130, 246, 0.1);
    color: rgb(59, 130, 246);
  }

  .lang-btn.active {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(139, 92, 246, 0.1) 100%);
    color: rgb(59, 130, 246);
    box-shadow: 0 0 10px rgba(59, 130, 246, 0.2);
  }
</style>

<script>
  import { setLanguage, type Language } from '../i18n/translations';

  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = (localStorage.getItem('language') || 'en') as Language;
    updateLanguageUI(savedLang);
    
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', (event) => {
        const lang = (event.currentTarget as HTMLButtonElement).dataset.lang as Language;
        if (lang) {
          setLanguage(lang);
          updateLanguageUI(lang);
          // Dispatch custom event for other components to listen
          window.dispatchEvent(new CustomEvent('languageChanged', { detail: { language: lang } }));
        }
      });
    });

    function updateLanguageUI(lang: Language) {
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      document.querySelector(`[data-lang="${lang}"]`)?.classList.add('active');
    }
  });
</script>