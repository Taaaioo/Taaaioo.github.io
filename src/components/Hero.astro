---
import profileImg from '../assets/profile.svg';
---

<section class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-20 parallax-container relative overflow-hidden">
  <!-- Parallax background elements -->
  <div class="absolute inset-0 parallax-bg pointer-events-none">
    <div class="absolute top-10 left-10 w-32 h-32 bg-accent rounded-full opacity-10 blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-20 w-40 h-40 bg-blue-600 rounded-full opacity-5 blur-3xl animate-pulse-slow"></div>
    <div class="absolute top-1/2 left-1/4 w-24 h-24 bg-purple-500 rounded-full opacity-5 blur-3xl animate-rotate"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center space-y-6 relative z-10">
    <!-- Profile image with animation -->
    <div class="flex justify-center mb-8">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-r from-accent to-blue-600 rounded-full opacity-30 blur-lg animate-glow"></div>
        <img 
          src={profileImg.src} 
          alt="Profile" 
          class="w-40 h-40 rounded-full border-4 border-accent animate-float relative z-10"
        />
      </div>
    </div>

    <div class="space-y-4 animate-slide-up">
      <h1 class="text-5xl md:text-7xl font-bold text-slate-50">
        Hi, I'm <span class="text-accent animate-pulse-slow">John Doe</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-400 animate-stagger-1">
        Full-Stack Software Engineer | Cloud Architect | Open Source Contributor
      </p>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto animate-stagger-2">
        Building scalable web applications and solving complex problems with modern technologies.
      </p>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center pt-8 animate-stagger-3">
      <a 
        href="#contact" 
        class="px-8 py-3 bg-accent text-slate-950 rounded-lg font-semibold hover:bg-blue-500 transition-all duration-200 transform hover:scale-105 hover-lift"
      >
        Get in Touch
      </a>
      <a 
        href="#projects" 
        class="px-8 py-3 border-2 border-accent text-accent rounded-lg font-semibold hover:bg-accent hover:text-slate-950 transition-all duration-200 hover-lift"
      >
        View My Work
      </a>
    </div>

    <!-- Social media icons with staggered animation -->
    <div class="pt-12 flex justify-center gap-6 animate-stagger-4">
      <a 
        href="https://github.com" 
        target="_blank" 
        class="text-slate-400 hover:text-accent transition text-2xl hover-lift transform hover:scale-110"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a 
        href="https://linkedin.com" 
        target="_blank" 
        class="text-slate-400 hover:text-accent transition text-2xl hover-lift transform hover:scale-110"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.047-8.842 0-9.769h3.554v1.383c.43-.664 1.199-1.608 2.925-1.608 2.135 0 3.735 1.39 3.735 4.38v5.614zM5.337 9.433c-1.144 0-1.915-.758-1.915-1.707 0-.957.77-1.708 1.971-1.708 1.2 0 1.914.751 1.939 1.708 0 .949-.739 1.707-1.995 1.707zm1.946 11.019H3.39V9.684h3.893v10.768zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
        </svg>
      </a>
      <a 
        href="https://twitter.com" 
        target="_blank" 
        class="text-slate-400 hover:text-accent transition text-2xl hover-lift transform hover:scale-110"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.953 4.57a10 10 0 002.856-9.53a10 10 0 01-2.82.856a4.958 4.958 0 00-8.86 3.04a4.934 4.934 0 00.12 1.013a14.046 14.046 0 01-10.18-5.16a4.934 4.934 0 001.526 6.573a4.903 4.903 0 01-2.24-.616c-.054 2.281 1.581 4.415 3.949 4.89a4.935 4.935 0 01-2.224.084a4.928 4.928 0 004.6 3.419A9.9 9.9 0 010 19.54a13.994 13.994 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator with animation -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-accent animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<style>
  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  :global(.animate-bounce) {
    animation: bounce 2s infinite;
  }
</style>
